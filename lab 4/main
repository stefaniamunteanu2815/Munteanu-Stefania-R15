#include <iostream>
#include "Sort.h"
using namespace std;
int main()
{
    int v1[] = { 5, 1, 9, 3, 7 };
    Sort s1(v1, 5);
    cout << "Constructor pointer: ";
    s1.BubbleSort(true);
    s1.Print();

    const int v2[] = { 10, 20, 30, 40 };
    Sort s2(v2, 4);
    cout << "Constructor alt vector: ";
    s2.InsertSort(true);
    s2.Print();

    Sort s3(5, 100, 1);
    cout << "Constructor random: ";
    s3.QuickSort(true);
    s3.Print();

    Sort s4(5, 50, 10, 90, 20, 70);
    cout << "Constructor variadic: ";
    s4.BubbleSort(true);
    s4.Print();

    Sort s5("10,40,100,5,70");
    cout << "Constructor string: ";
    s5.InsertSort(true);
    s5.Print();

    cout << "\nInsertSort\n";
    s5.InsertSort(true);
    s5.Print();

    cout << "BubbleSort\n";
    Sort s6("9,1,8,2,7,3");
    s6.BubbleSort(true);
    s6.Print();

    cout << "QuickSort \n";
    Sort s7("50,10,40,90,30,70,20");
    s7.QuickSort(true);
    s7.Print();

    return 0;
}
