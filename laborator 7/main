#include <iostream>
#include "Tree.h"
using namespace std;

float operator "" _Kelvin(unsigned long long int v) 
{
    return (float)(v - 273.15);
}

float operator "" _Fahrenheit(unsigned long long int v) 
{
    return (float)((v - 32) * 5.0 / 9.0);
}

int main() 
{
    float a = 300_Kelvin;
    float b = 120_Fahrenheit;

    std::cout << "300 Kelvin in Celsius: " << a << endl;
    std::cout << "120 Fahrenheit in Celsius: " << b << "\n\n";

    Tree<int> t;
    Node<int>* root = t.add_node(nullptr, 10);
    Node<int>* n1 = t.add_node(root, 50);
    Node<int>* n2 = t.add_node(root, 20);

    t.insert(root, 1, 30);

    cout << "Total noduri: " << t.count(nullptr) << endl;

    t.sort(root, [](int a, int b) { return a > b; });

    Node<int>* found = t.find([](int val) { return val == 30; });
    if (found) cout << "Am gasit nodul cu valoarea: " << found->value << endl;

    return 0;
}
